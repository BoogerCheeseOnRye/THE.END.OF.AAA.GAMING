  },
  "pkg": {
    "assets": [],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist-server"
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "catalog:",
    "pkg": "^5.8.1",
    "vite": "catalog:"
  }
}
